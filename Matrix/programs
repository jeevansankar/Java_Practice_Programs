8. Largest Element
public class Main {

    public static void main(String[] args) {

        int[][] arr = {
                {1,2,30},
                {4,50,6},
                {7,8,9}
        };

        int max = arr[0][0];

        for(int i=0; i<arr.length; i++){

            for(int j=0; j<arr[i].length; j++){

                if(arr[i][j] > max){

                    max = arr[i][j];
                }
            }
        }

        System.out.println(max);
    }
}
9. Matrix Addition
public class Main {

    public static void main(String[] args) {

        int[][] a = {
                {1,2},
                {3,4}
        };

        int[][] b = {
                {5,6},
                {7,8}
        };

        int[][] sum = new int[2][2];

        for(int i=0; i<2; i++){

            for(int j=0; j<2; j++){

                sum[i][j] = a[i][j] + b[i][j];
            }
        }

        for(int i=0; i<2; i++){

            for(int j=0; j<2; j++){

                System.out.print(sum[i][j] + " ");
            }

            System.out.println();
        }
    }
}
10. Matrix Multiplication

This is important for interviews.

public class Main {

    public static void main(String[] args) {

        int[][] a = {
                {1,2},
                {3,4}
        };

        int[][] b = {
                {5,6},
                {7,8}
        };

        int[][] result = new int[2][2];

        for(int i=0; i<2; i++){

            for(int j=0; j<2; j++){

                for(int k=0; k<2; k++){

                    result[i][j] += a[i][k] * b[k][j];
                }
            }
        }

        for(int i=0; i<2; i++){

            for(int j=0; j<2; j++){

                System.out.print(result[i][j] + " ");
            }

            System.out.println();
        }
    }
}