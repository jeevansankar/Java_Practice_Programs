6. Search Element
public class Main {

    public static void main(String[] args) {

        int[][] arr = {
                {1,2,3},
                {4,5,6},
                {7,8,9}
        };

        int target = 6;

        boolean found = false;

        for(int i=0; i<arr.length; i++){

            for(int j=0; j<arr[i].length; j++){

                if(arr[i][j] == target){

                    System.out.println("Found at: " + i + "," + j);

                    found = true;
                }
            }
        }

        if(!found){

            System.out.println("Not Found");
        }
    }
}
7. Transpose Matrix

